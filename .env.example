# KrishiAI Environment Configuration Template
# Copy this file to .env and fill in your values

# =====================================================
# DATABASE CONFIGURATION
# =====================================================

# PostgreSQL Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/krishiai
SPRING_DATASOURCE_USERNAME=krishiai_user
SPRING_DATASOURCE_PASSWORD=secure_password_123
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# =====================================================
# JWT CONFIGURATION
# =====================================================

# Generate secure JWT secret: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_recommended_change_this_in_production
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
JWT_ALGORITHM=HS256

# =====================================================
# REDIS CONFIGURATION
# =====================================================

SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=redis_password
SPRING_REDIS_TIMEOUT=60000
SPRING_CACHE_TYPE=redis
SPRING_CACHE_REDIS_TIME_TO_LIVE=3600000

# =====================================================
# AWS CONFIGURATION
# =====================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# S3 Configuration
AWS_S3_BUCKET=krishiai-uploads
AWS_S3_REGION=ap-south-1
AWS_S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com

# =====================================================
# EXTERNAL API KEYS
# =====================================================

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_open_weather_api_key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Market Data API
MARKET_DATA_API_KEY=your_market_data_key
MARKET_DATA_API_URL=https://api.example.com/market

# =====================================================
# EMAIL CONFIGURATION
# =====================================================

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true

# =====================================================
# SMS CONFIGURATION (Twilio/AWS SNS)
# =====================================================

SMS_PROVIDER=twilio  # or sns
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# =====================================================
# APPLICATION CONFIGURATION
# =====================================================

APP_NAME=KrishiAI
APP_VERSION=1.0.0
APP_ENVIRONMENT=development  # development, staging, production
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# =====================================================
# LOGGING CONFIGURATION
# =====================================================

LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_KRISHIAI=DEBUG
LOGGING_FILE_NAME=logs/application.log
LOGGING_FILE_MAX_SIZE=10MB
LOGGING_FILE_MAX_HISTORY=10

# =====================================================
# AI/ML CONFIGURATION
# =====================================================

AI_SERVICE_URL=http://localhost:5000
AI_SERVICE_TIMEOUT=60000
AI_MODEL_PATH=/models
AI_MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# =====================================================
# CORS CONFIGURATION
# =====================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://app.krishiai.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# =====================================================
# RATE LIMITING
# =====================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# =====================================================
# SECURITY
# =====================================================

SECURITY_ENABLE_HTTPS=false  # Set to true in production
SECURITY_SSL_KEYSTORE_PATH=/path/to/keystore.p12
SECURITY_SSL_KEYSTORE_PASSWORD=keystore_password
SECURITY_SSL_KEYSTORE_TYPE=PKCS12

# =====================================================
# MONITORING & METRICS
# =====================================================

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# =====================================================
# ACTUATOR
# =====================================================

MANAGEMENT_ENDPOINTS_WEB_BASE_PATH=/actuator
MANAGEMENT_ENDPOINT_SHUTDOWN_ENABLED=false

# =====================================================
# FRONTEND CONFIGURATION
# =====================================================

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_NAME=KrishiAI
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=development

# =====================================================
# PYTHON AI SERVICE CONFIGURATION
# =====================================================

FLASK_ENV=development
FLASK_DEBUG=True
MODEL_PATH=./models
DATA_PATH=./data
LOG_LEVEL=INFO
GPU_ENABLED=false

# =====================================================
# DATABASE BACKUP
# =====================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups

# =====================================================
# ANALYTICS & TRACKING
# =====================================================

ANALYTICS_ENABLED=true
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
SENTRY_DSN=https://your_sentry_dsn

# =====================================================
# FEATURE FLAGS
# =====================================================

FEATURE_DISEASE_DETECTION=true
FEATURE_VOICE_ASSISTANT=false
FEATURE_MARKETPLACE=false
FEATURE_LABOR_MARKETPLACE=false
FEATURE_WAREHOUSE_FINDER=true
FEATURE_FINANCE=false

# =====================================================
# NOTIFICATION CONFIGURATION
# =====================================================

NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true
NOTIFICATION_PUSH_ENABLED=false

# =====================================================
# DATA RETENTION POLICY
# =====================================================

DATA_RETENTION_DAYS_TEMP=30
DATA_RETENTION_DAYS_LOGS=90
DATA_RETENTION_DAYS_AUDIT=365

# =====================================================
# DISASTER RECOVERY
# =====================================================

DISASTER_RECOVERY_ENABLED=true
DR_BACKUP_REGION=ap-south-2
DR_RTO_MINUTES=30
DR_RPO_MINUTES=5
